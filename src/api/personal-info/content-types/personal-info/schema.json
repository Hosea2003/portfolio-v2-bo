{
  "kind": "singleType",
  "collectionName": "personal_infos",
  "info": {
    "singularName": "personal-info",
    "pluralName": "personal-infos",
    "displayName": "Personal Info",
    "description": "Personal information displayed on the portfolio"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "role": {
      "type": "string",
      "required": true
    },
    "subtitle": {
      "type": "string"
    },
    "bio": {
      "type": "text"
    },
    "heroCtaText": {
      "type": "string",
      "default": "Hire me"
    },
    "profileImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "resume": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["files"]
    },
    "socialLinks": {
      "type": "component",
      "repeatable": true,
      "component": "shared.social-link"
    },
    "email": {
      "type": "email"
    }
  }
}
