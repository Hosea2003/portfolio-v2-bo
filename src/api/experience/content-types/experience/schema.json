{
  "kind": "collectionType",
  "collectionName": "experiences",
  "info": {
    "singularName": "experience",
    "pluralName": "experiences",
    "displayName": "Experience",
    "description": "Professional work experience"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "role": {
      "type": "string",
      "required": true
    },
    "company": {
      "type": "string",
      "required": true
    },
    "companyLogo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "companyUrl": {
      "type": "string"
    },
    "startDate": {
      "type": "date",
      "required": true
    },
    "endDate": {
      "type": "date"
    },
    "isCurrent": {
      "type": "boolean",
      "default": false
    },
    "description": {
      "type": "text",
      "required": true
    },
    "technologies": {
      "type": "json"
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
